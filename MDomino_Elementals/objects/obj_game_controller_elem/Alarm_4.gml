/// obj_game_controller_elem - Alarm 4 (Конец демонстрации стартовой кости)

// 1. Выключаем режим показа стартовой заставки
global.is_showing_starter = false;

// 2. Визуально выставляем стартовую кость на стол через общую функцию хода
// Мы передаем в функцию play_domino стартовую кость, которую нашли в Alarm 0
if (instance_exists(global.starter_tile)) {
    global.play_domino(global.starter_tile, "first");
}

// 3. Активируем ИИ, если первый ход выпал компьютеру
// Мы используем задержку в 30-40 кадров, чтобы после появления кости на столе 
// была небольшая пауза перед следующим действием.
if (global.current_turn == "computer") {
    alarm[1] = 40; 
}

// Примечание: Если ход игрока, контроллер просто переходит в режим ожидания 
// клика по костяшкам в obj_domino_elem.