/// obj_game_controller_elem - Global Right Pressed (Отмена выбора)

// Если игрок в данный момент выбирает, куда положить кость (лево/право)
if (global.choice_mode) {
    // 1. Выключаем режим выбора
    global.choice_mode = false;
    
    // 2. Сбрасываем ссылку на выбранный экземпляр костяшки
    global.selected_domino = noone;
    
    // 3. Визуально возвращаем кости игрока в нормальное положение.
    // В классическом коде кость обычно приподнимается по Y при выборе.
    // Вызываем метод перерисовки руки у нового объекта игрока.
    if (instance_exists(obj_player_hand_elem)) {
        with (obj_player_hand_elem) {
            // Вызываем вашу функцию упорядочивания (убедитесь, что имя совпадает)
            arrange_player_hand(); 
        }
    }
}