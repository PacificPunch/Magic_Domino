/// @desc obj_game_controller_b_x2 - Alarm 0 Event
/// Первичное упорядочивание рук после раздачи

// 1. Проверяем существование объекта руки игрока и обновляем его список
if (instance_exists(obj_player_hand_b_x2)) {
    with (obj_player_hand_b_x2) {
        // Вызываем метод упорядочивания (который должен быть внутри obj_player_hand_b_x2)
        // Он распределит 14 костяшек по экрану
        arrange_player_hand();
    }
}

// 2. Проверяем существование объекта руки компьютера и обновляем его список
if (instance_exists(obj_computer_hand_b_x2)) {
    with (obj_computer_hand_b_x2) {
        // Вызываем метод упорядочивания для бота
        arrange_computer_hand();
    }
}

// 3. Устанавливаем видимость костяшек
// После того как координаты рассчитаны, делаем костяшки видимыми
with (obj_domino_b_x2) {
    if (owner == "player") {
        visible = true;
    }
    // Костяшки бота оставляем видимыми, но Draw Event сам решит рисовать рубашку
    if (owner == "computer") {
        visible = true; 
    }
}

// 4. Логика первого хода (опционально)
// Если в игре еще нет костей на столе, можно запустить проверку на самый большой дубль
if (ds_list_size(global.table_chain) == 0) {
    // alarm[1] = 30; // Например, запуск определения стартера
}