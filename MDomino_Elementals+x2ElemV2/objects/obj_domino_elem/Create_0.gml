/// obj_domino_elem - Create Event

// --- СВОЙСТВА КОСТЯШКИ (Классика) ---
value1 = 0;        // Значение первой половины
value2 = 0;        // Значение второй половины
owner = "none";    // Владелец: "player", "computer", "bazar", "table"
my_index = 0;      // Порядковый индекс в руке
is_horizontal = true; 
selected = false;

// Визуальные настройки
sprite_index = spr_00; // По умолчанию, изменится при создании в контроллере
image_index  = 0;
depth = -10;

// Логика перетаскивания (Mouse Dragging)
dragging = false;      
offset_x = 0;          
offset_y = 0;

// --- СВОЙСТВА ELEMENTAL (НОВЫЕ ПРАВИЛА) ---

// Проверка на дубль
// ПРИМЕЧАНИЕ: Теперь дубли НЕ являются мостами и подчиняются общим правилам стихий.
is_double = false; 

// ИСПРАВЛЕНО: Теперь у костяшки ДВЕ разные стихии (по одной на каждую половинку).
// Для дублей эти значения будут одинаковыми.
element1 = ELEMENT.NONE; 
element2 = ELEMENT.NONE; 

// Мы вызываем Alarm[11], чтобы проверить свои значения и определить элементы 
// ПОСЛЕ того, как контроллер передаст нам нужные value и sprite_index
alarm[11] = 1;