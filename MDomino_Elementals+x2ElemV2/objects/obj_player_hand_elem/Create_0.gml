/// obj_player_hand_elem - Create Event

/**
 * Функция визуального упорядочивания костей в руке игрока.
 * Вызывается каждый раз, когда игрок берет кость из базара 
 * или выкладывает её на стол.
 */
function arrange_player_hand() {
    // Защита от вылетов при перезапуске игры или смене комнаты
    if (!variable_global_exists("player_hand")) return;
    
    // Получаем количество костей в руке из глобального списка
    var count = ds_list_size(global.player_hand);
    
    // Если рука пуста, ничего не делаем
    if (count <= 0) return;
    
    // Настройки позиционирования
    var spacing = 72; // Расстояние между центрами костей
    var total_width = (count - 1) * spacing;
    
    // Вычисляем начальную координату X, чтобы рука всегда была центрирована
    var start_x = 1920 / 2 - total_width / 2;
    
    // Базовая позиция по Y (нижняя часть экрана)
    var y_pos   = 1080 - 160; 
    
    // Проходим по списку всех костей в руке
    for (var i = 0; i < count; i++) {
        var inst = global.player_hand[| i];
        
        // Проверка на существование экземпляра, чтобы избежать ошибок
        if (instance_exists(inst)) {
            // Устанавливаем координаты по оси X
            inst.x = start_x + i * spacing;
            
            // Если кость сейчас НЕ выбрана для двойного хода (не приподнята в choice_mode),
            // возвращаем её на стандартную высоту.
            if (!global.choice_mode || inst != global.selected_domino) {
                inst.y = y_pos;
            }
            
            // Настраиваем глубину отрисовки (чем правее кость, тем она "выше")
            inst.depth = -200 - i;
            
            // В руке кости всегда стоят вертикально (0 градусов)
            inst.image_angle = 0;
            
            // Делаем кость видимой для игрока
            inst.visible = true;
            
            // Обновляем внутренний индекс кости
            inst.my_index = i;
            
            // ВАЖНО: Сбрасываем флаг перетаскивания, если он случайно залип при отпускании мыши
            inst.dragging = false; 
        }
    }
}