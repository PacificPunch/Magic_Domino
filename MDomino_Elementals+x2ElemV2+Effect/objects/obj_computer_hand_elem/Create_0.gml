/// obj_computer_hand_elem - Create Event

/**
 * Функция визуального упорядочивания костей в руке компьютера.
 * Вызывается при стартовой раздаче, доборе из базара или совершении хода.
 */
function arrange_computer_hand() {
    // Проверка на существование списка, чтобы избежать вылетов при перезагрузке
    if (!variable_global_exists("computer_hand")) return;
    
    var count = ds_list_size(global.computer_hand);
    
    // Если рука пуста, делать нечего
    if (count <= 0) return;
    
    // Настройки сетки
    // Кости компьютера стоят чуть плотнее (68 пикселей), чем у игрока, 
    // чтобы визуально различать руки и экономить место сверху.
    var spacing = 68; 
    var total_width = (count - 1) * spacing;
    
    // Центрируем руку по горизонтали относительно игрового поля (1920x1080)
    var start_x = 1920 / 2 - total_width / 2;
    
    // Позиция по вертикали (верхняя часть экрана)
    var y_pos   = 90; 
    
    // Проходим по списку всех костей, которыми владеет компьютер
    for (var i = 0; i < count; i++) {
        var inst = global.computer_hand[| i];
        
        if (instance_exists(inst)) {
            // Устанавливаем координаты
            inst.x = start_x + i * spacing;
            inst.y = y_pos;
            
            // Настраиваем глубину: чем правее кость, тем она "выше" по Z-оси
            inst.depth = -200 - i;
            
            // В руке костяшки всегда стоят вертикально (0 градусов)
            inst.image_angle = 0;
            
            // Делаем кость видимой для движка. 
            // Примечание: Draw Event самой кости сам решит рисовать рубашку, 
            // так как владелец - "computer".
            inst.visible = true;
            
            // Обновляем внутренний индекс для системного порядка
            inst.my_index = i;
            
            // Сбрасываем флаги взаимодействия (защита от случайных срабатываний логики игрока)
            inst.dragging = false;
            inst.selected = false;
        }
    }
}