/// obj_game_controller_elem - Alarm 4 (Завершение стартовой заставки)

// 1. Выключаем визуальный флаг заставки
// Как только этот флаг станет false, кости перестанут пульсировать,
// а в Step Event контроллера сработает условие для запуска таймера хода ИИ.
global.is_showing_starter = false;

// 2. Финализируем очередь хода
// Мы проверяем владельца стартовой кости, которую нашли в Alarm 0.
if (instance_exists(global.starter_tile)) {
    // Устанавливаем очередь того, у кого оказалась минимальная кость
    global.current_turn = global.starter_tile.owner;
} else {
    // Резервный случай: если кость не найдена (не должно случаться), начинаем с игрока
    global.current_turn = "player";
}

/* ЛОГИКА ПЕРЕХОДА:
  - Если сейчас ход компьютера, то Step Event контроллера увидит, что 
    current_turn == "computer" и is_showing_starter == false, 
    после чего запустит Alarm 1 (ход ИИ) через 60 кадров.
  - Если ход игрока, игра просто будет ждать его действий (кликов или перетаскивания).
*/